+// BSFAwarePCFSelection performs PCF selection with BSF binding awareness
+func (c *Consumer) BSFAwarePCFSelection(smContext *smf_context.SMContext) error {
+	return c.nbsfService.PCFSelectionWithBSF(smContext)
+}
